# ── Client (build-time, public) ───────────────────────────────────────────────
# Convex deployment client URL. Baked into the browser bundle at build time.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# ── Server (runtime, secret) ──────────────────────────────────────────────────
# Convex URL used by the Node server (ConvexHttpClient). Usually same as above.
CONVEX_URL=https://your-deployment.convex.cloud

# Shared secret authorizing the Node server -> Convex server functions.
# Must match the FORGE_SERVER_SECRET set on the Convex deployment.
FORGE_SERVER_SECRET=generate-a-long-random-string

# OpenAI key used by the generation edge (runs on the VPS, not Convex).
OPENAI_API_KEY=sk-...

# Tavily key used by the task harness research stage (SERP + page content).
TAVILY_API_KEY=tvly-...
# Set to "fake" to run the harness with canned search results (local dev/testing
# without a Tavily key). Leave unset in production.
# FORGE_SEARCH_PROVIDER=fake

# ── Convex deployment env vars (set with `npx convex env set ...`) ─────────────
# FORGE_SERVER_SECRET=<same value as above>
# Convex Auth also needs JWT_PRIVATE_KEY, JWKS and SITE_URL — generate via
# `npx @convex-dev/auth` once when wiring auth to a real deployment.

# ── Local development only (written by `npx convex dev`) ───────────────────────
# CONVEX_DEPLOYMENT=...
